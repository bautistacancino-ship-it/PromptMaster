{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and metadata",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "generatedPrompt": {
      "title": "Generated Prompt",
      "description": "Stores prompts generated by the user",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Owner UID" },
        "tool": { "type": "string" },
        "topic": { "type": "string" },
        "prompt": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "prompt", "createdAt"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "userProfile",
      "description": "User profile documents"
    },
    "/users/{uid}/prompts/{promptId}": {
      "schema": "generatedPrompt",
      "description": "History of prompts generated by the user"
    }
  }
}
